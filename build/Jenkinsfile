pipeline {
    agent { label 'ec2' }

    parameters {
        choice(name: 'ENVIRONMENT', choices: ['dev', 'qa', 'prod'], description: 'Select target environment namespace')
    }

    environment {
        TERRAFORM_DIR = './deploy/terraformscripts'
        ANSIBLE_DIR   = './deploy/playbooks'
    }

    options {
        timestamps()
        timeout(time: 60, unit: 'MINUTES')
    }

    stages {
        stage('Prepare Tools') {
            steps {
                                echo 'Ensure ansible and terraform are available on the agent (will install terraform if missing)'
                                sh '''#!/bin/bash -l
                                set -e
                                # Install Terraform if missing
                                if ! command -v terraform >/dev/null 2>&1; then
                                    echo "Terraform not found, installing..."
                                    TF_VERSION=1.15.6
                                    TF_ZIP="terraform_${TF_VERSION}_linux_amd64.zip"
                                    if [ ! -f "${TF_ZIP}" ]; then
                                        wget "https://releases.hashicorp.com/terraform/${TF_VERSION}/${TF_ZIP}"
                                    fi
                                    unzip -o "${TF_ZIP}"
                                    sudo mv -f terraform /usr/local/bin/terraform
                                    rm -f "${TF_ZIP}"
                                else
                                    echo "Terraform already installed: $(terraform --version | head -n1)"
                                fi

                                # Ensure ansible is present (best-effort installation)
                                if ! command -v ansible-playbook >/dev/null 2>&1; then
                                    echo "Ansible not found, attempting to install..."
                                    sudo yum install -y ansible || echo 'yum install ansible failed'
                                else
                                    echo "Ansible already installed: $(ansible --version | head -n1)"
                                fi

                                terraform --version || true
                                ansible --version || true
                                '''
            }
        }

        stage('Terraform: Init & Validate') {
            steps {
                dir("${TERRAFORM_DIR}") {
                    sh 'terraform init -input=false'
                    sh 'terraform fmt -check || terraform fmt'
                    sh 'terraform validate || true'
                }
            }
        }

        stage('Terraform: Plan & Apply') {
            steps {
                dir("${TERRAFORM_DIR}") {
                    withEnv(["TF_IN_AUTOMATION=1"]) {
                        sh 'terraform plan -out=tfplan -input=false || true'
                        sh 'terraform apply -input=false -auto-approve tfplan'
                    }
                }
            }
        }

        stage('Sync Inventory') {
            steps {
                dir("${TERRAFORM_DIR}") {
                    script {
                        if (fileExists('inventory')) {
                            sh 'cp inventory ../playbooks/inventory'
                            echo 'Inventory copied to playbooks'
                        } else {
                            echo 'No inventory found in terraform dir; skipping copy.'
                        }
                    }
                }
            }
        }

        stage('Configure Kubernetes') {
            steps {
                dir("${ANSIBLE_DIR}") {
                    withCredentials([file(credentialsId: 'ssh-private-key', variable: 'SSH_KEY')]) {
                        //sh 'touch gfg37ansible.pem'
                        sh 'cp ${SSH_KEY} ./gfg37ansible.pem && chmod 400 gfg37ansible.pem'
                        sh 'sleep 60' // Wait for instances to be ready
                        sh 'ansible-playbook -i inventory k8s_common.yaml'
                        sh 'ansible-playbook -i inventory k8s_master.yaml'
                        sh 'ansible-playbook -i inventory k8s_workers.yaml'
                    }
                }
            }
        }

        stage('Deploy & Monitoring (parallel)') {
            parallel {
                stage('Monitoring') {
                    steps {
                        dir("${ANSIBLE_DIR}") {
                            sh 'ansible-playbook -i inventory prometheus-grafana.yml'
                        }
                    }
                }
                stage('Application Deploy') {
                    steps {
                        dir("${ANSIBLE_DIR}") {
                            script {
                                echo "Deploying to ${params.ENVIRONMENT} environment..."
                                sh """
                                    ansible-playbook -i inventory deployDeployment.yml \
                                    --extra-vars "namespace=${params.ENVIRONMENT} app_name=gfgdeployment"
                                """
                            }
                        }
                    }
                }
            }
        }

       // Environment Promotion Flow
        stage('Promote to QA') {
            steps {
                script {
                    timeout(time: 2, unit: 'MINUTES') {  //Auto abort after 2 minutes
                    input message: "Proceed with deployment to QA?", ok: "Deploy QA"
                    }
                    dir("${ANSIBLE_DIR}") {
                        sh """
                            ansible-playbook -i inventory deployDeployment.yml \
                            --extra-vars "namespace=qa app_name=gfgdeployment"
                        """
                    }
                }
            }
        }

        stage('Promote to PROD') {
            steps {
                script {
                    timeout(time: 2, unit: 'MINUTES') { // Auto abort after 2 minutes
                    input message: "Promote to PROD environment?", ok: "Deploy PROD"
                    }
                    dir("${ANSIBLE_DIR}") {
                        sh """
                            ansible-playbook -i inventory deployDeployment.yml \
                            --extra-vars "namespace=prod app_name=gfgdeployment"
                        """
                    }
                }
            }
        }
    }

    post {
        always {
            echo 'Pipeline finished'
            archiveArtifacts artifacts: 'deploy/terraformscripts/*.tfstate, deploy/terraformscripts/inventory', allowEmptyArchive: true
        }
        success {
            echo "Deployment successful to ${params.ENVIRONMENT} environment"
        }
        failure {
            echo "Deployment failed for ${params.ENVIRONMENT} environment"
        }
    }
}
